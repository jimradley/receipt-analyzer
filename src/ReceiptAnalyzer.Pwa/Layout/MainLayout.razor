@inherits LayoutComponentBase
@implements IDisposable
@inject AuthService Auth
@inject NavigationManager Nav

<div class="app-shell">
    <header class="app-bar">
        <div class="app-bar__inner">
            <a class="app-bar__brand" href="">
                <span class="app-bar__logo" aria-hidden="true">🧾</span>
                <span class="app-bar__title">Receipt Analyzer</span>
            </a>
            @if (_authed)
            {
                <nav class="app-bar__links">
                    <a class="app-bar__nav" href="">Upload</a>
                    <a class="app-bar__nav" href="stores">Stores</a>
                    <a class="app-bar__nav" href="staples">Staples</a>
                    <a class="app-bar__nav" href="spend">Spend</a>
                    <a class="app-bar__nav" href="history">History</a>
                    <a class="app-bar__nav" href="costs">Costs</a>
                    <a class="app-bar__nav" href="#" @onclick="Logout" @onclick:preventDefault="true">Logout</a>
                </nav>
            }
        </div>
    </header>

    <main class="app-main">
        <div class="app-container">
            @if (OnLogin || _authed)
            {
                @Body
            }
            else
            {
                <div class="text-muted p-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading…</div>
            }
        </div>
    </main>
</div>

@code {
    private bool _authed;

    private bool OnLogin =>
        Nav.ToBaseRelativePath(Nav.Uri).TrimStart('/').StartsWith("login", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    protected override async Task OnInitializedAsync()
    {
        _authed = await Auth.IsAuthenticatedAsync();
        if (!_authed && !OnLogin) Nav.NavigateTo("login");
        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("login", forceLoad: true);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
