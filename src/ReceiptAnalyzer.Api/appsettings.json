{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Agent": {
    "Provider": "claude-code",
    "Model": "gpt-4o",
    "PriceCheckModel": "gpt-5-mini",
    "ApiKeyEnvVar": "OPENAI_API_KEY",
    "RulesFilePath": "rules.txt",
    "_comment": "Model/PriceCheckModel/ApiKeyEnvVar above are the openai fallback's settings — kept so flipping Provider back to \"openai\" just works. The claude-code provider (default) is configured separately below.",
    "ClaudeCode": {
      "BridgeUrl": "http://localhost:5095",
      "BridgeKeyEnvVar": "RECEIPT_BRIDGE_KEY",
      "Model": "claude-sonnet-5",
      "TimeoutSeconds": 600
    }
  },
  "Reports": {
    "OutputDir": "./reports"
  },
  "Jobs": {
    "RetentionDays": 14,
    "PriceCacheDays": 7,
    "PriceCacheNotFoundDays": 1,
    "PriceCheckChunkSize": 4,
    "PriceCheckRetryMax": 8
  },
  "Auth": {
    "_comment": "Dev defaults only. In production set Auth__RpId and Auth__Origins via env (the real host stays out of the repo).",
    "RpId": "localhost",
    "Origins": "https://localhost:5080,http://localhost:5080"
  },
  "Pricing": {
    "UsdToGbp": 0.79,
    "Models": {
      "claude-sonnet-4-6": { "InputPerMTok": 3.00, "OutputPerMTok": 15.00, "CacheReadPerMTok": 0.30, "CacheWritePerMTok": 3.75 },
      "gpt-4o": { "InputPerMTok": 2.50, "OutputPerMTok": 10.00, "CacheReadPerMTok": 1.25, "CacheWritePerMTok": 0.00 },
      "gpt-5-mini": { "InputPerMTok": 0.25, "OutputPerMTok": 2.00, "CacheReadPerMTok": 0.025, "CacheWritePerMTok": 0.00 },
      "claude-sonnet-5": { "InputPerMTok": 0.00, "OutputPerMTok": 0.00, "CacheReadPerMTok": 0.00, "CacheWritePerMTok": 0.00 }
    }
  }
}
